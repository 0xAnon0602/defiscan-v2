{
  "$schema": "../../../../discovery/schemas/config.v2.schema.json",
  "name": "Steakhouse-USDC",
  "import": ["../globalConfig.jsonc"],
  "initialAddresses": ["eth:0xBEEF01735c132Ada46AA9aA4c54623cAA92A64CB"],
  "maxAddresses": 100,
  "overrides": {
    "eth:0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48": {
      "ignoreDiscovery": true
    },
    "eth:0xCA06411bd7a7296d7dbdd0050DFc846E95fEBEB7": {
      "ignoreDiscovery": true
    },
    "eth:0xe5A5F138005E19A3E6D0FE68b039397EeEf2322b": {
      "ignoreDiscovery": true
    },
    "eth:0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0": {
      "ignoreDiscovery": true
    },
    // weETH (EtherFi) — collateral leaf for the weETH/USDC market. Cuts off the
    // entire EtherFi protocol tree (timelock, role registry, liquidity pool,
    // staking manager, oracle, redemption manager, etc.) plus the Lido stETH /
    // Coinbase cbETH / Curve Vyper pools EtherFi pulls in internally.
    "eth:0xCd5fE23C85820F7B72D0926FC9b05b43E359b7ee": {
      "ignoreDiscovery": true
    },
    "eth:0xBEEF01735c132Ada46AA9aA4c54623cAA92A64CB": {
      "ignoreMethods": [
        "convertToShares",
        "convertToAssets",
        "previewDeposit",
        "previewMint",
        "previewRedeem",
        "previewWithdraw"
      ],
      "fields": {
        "supplyQueue": {
          "handler": {
            "type": "array",
            "method": "supplyQueue",
            "length": "{{ supplyQueueLength }}"
          }
        },
        "withdrawQueue": {
          "handler": {
            "type": "array",
            "method": "withdrawQueue",
            "length": "{{ withdrawQueueLength }}"
          }
        },
        "marketParams": {
          "handler": {
            "type": "morphoMarkets",
            "morphoAddressField": "MORPHO",
            "queueField": "withdrawQueue",
            "ignoreRelative": true
          }
        },
        "allocators": {
          "handler": {
            "type": "event",
            "select": "allocator",
            "add": {
              "event": "SetIsAllocator",
              "where": ["=", "#isAllocator", true]
            },
            "remove": {
              "event": "SetIsAllocator",
              "where": ["!=", "#isAllocator", true]
            }
          }
        },
        "marketOracles": {
          "handler": {
            "type": "morphoMarkets",
            "extractField": "oracle",
            "sourceField": "marketParams"
          }
        },
        "MAX_TIMELOCK": {
          "handler": {
            "type": "hardcoded",
            "value": 1209600
          },
          "description": "Maximum timelock delay (2 weeks)"
        },
        "MIN_TIMELOCK": {
          "handler": {
            "type": "hardcoded",
            "value": 86400
          },
          "description": "Minimum timelock delay (1 day)"
        },
        "MAX_QUEUE_LENGTH": {
          "handler": {
            "type": "hardcoded",
            "value": 30
          },
          "description": "Maximum number of markets in supply/withdraw queue"
        },
        "MAX_FEE": {
          "handler": {
            "type": "hardcoded",
            "value": "500000000000000000"
          },
          "description": "Maximum fee (50%, represented as 0.5e18)"
        },
        "fee": {
          "severity": "HIGH"
        },
        // Per-feed caps: SUM of caps across markets that consume this Chainlink feed.
        // queueField=withdrawQueue so the cap aggregation considers the full universe (the handler skips oracle=0x0).
        "feedCap_0x86392dC19c0b719886221c78AB11eb8Cf5c52812": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0x86392dC19c0b719886221c78AB11eb8Cf5c52812", "queueField": "withdrawQueue" }
        },
        "feedCap_0x986b5E1e1755e3C2440e960477f25201B0a8bbD4": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0x986b5E1e1755e3C2440e960477f25201B0a8bbD4", "queueField": "withdrawQueue" }
        },
        "feedCap_0xc0053f3FBcCD593758258334Dfce24C2A9A673aD": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0xc0053f3FBcCD593758258334Dfce24C2A9A673aD", "queueField": "withdrawQueue" }
        },
        "feedCap_0x8fFfFfd4AfB6115b954Bd326cbe7B4BA576818f6": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0x8fFfFfd4AfB6115b954Bd326cbe7B4BA576818f6", "queueField": "withdrawQueue" }
        },
        "feedCap_0xF4030086522a5bEEa4988F8cA5B36dbC97BeE88c": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0xF4030086522a5bEEa4988F8cA5B36dbC97BeE88c", "queueField": "withdrawQueue" }
        },
        "feedCap_0xfdFD9C85aD200c506Cf9e21F1FD8dd01932FBB23": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0xfdFD9C85aD200c506Cf9e21F1FD8dd01932FBB23", "queueField": "withdrawQueue" }
        },
        "feedCap_0x4F67e4d9BD67eFa28236013288737D39AeF48e79": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0x4F67e4d9BD67eFa28236013288737D39AeF48e79", "queueField": "withdrawQueue" }
        },
        // WeEthToEthExchangeRateAdapter — BASE_FEED_1 of the weETH/USDC market oracle.
        // Mirrors the WstETHPriceFeed pattern so the weETH-rate dependency edge inherits a cap.
        "feedCap_0x4270E1817576bbA4b640466bE79A408Ef128F828": {
          "handler": { "type": "metaMorphoCap", "mode": "feed", "feed": "0x4270E1817576bbA4b640466bE79A408Ef128F828", "queueField": "withdrawQueue" }
        }
      },
      "ignoreInWatchMode": [
        "totalAssets",
        "totalSupply",
        "lastTotalAssets",
        "feedCap_0x86392dC19c0b719886221c78AB11eb8Cf5c52812",
        "feedCap_0x986b5E1e1755e3C2440e960477f25201B0a8bbD4",
        "feedCap_0xc0053f3FBcCD593758258334Dfce24C2A9A673aD",
        "feedCap_0x8fFfFfd4AfB6115b954Bd326cbe7B4BA576818f6",
        "feedCap_0xF4030086522a5bEEa4988F8cA5B36dbC97BeE88c",
        "feedCap_0xfdFD9C85aD200c506Cf9e21F1FD8dd01932FBB23",
        "feedCap_0x4F67e4d9BD67eFa28236013288737D39AeF48e79",
        "feedCap_0x4270E1817576bbA4b640466bE79A408Ef128F828"
      ]
    },
    "eth:0x4a3411ac2948B33c69666B35cc6d055B27Ea84f1": {
      "ignoreMethods": ["getTransmitters"]
    },
    "eth:0x8fFfFfd4AfB6115b954Bd326cbe7B4BA576818f6": {
      "ignoreRelatives": ["aggregator"]
    },
    "eth:0xfdFD9C85aD200c506Cf9e21F1FD8dd01932FBB23": {
      "ignoreMethods": ["proposedAggregator", "getAnswer", "getTimestamp"],
      "ignoreRelatives": [
        "aggregator"
      ],
      "ignoreInWatchMode": [
        "getAnswer",
        "latestAnswer"
      ]
    },
    "eth:0x86392dC19c0b719886221c78AB11eb8Cf5c52812": {
      "ignoreRelatives": ["aggregator"]
    },
    "eth:0xc0053f3FBcCD593758258334Dfce24C2A9A673aD": {
      "ignoreRelatives": ["aggregator"]
    },
    // weETH/ETH exchange rate adapter (Morpho-side feed for the weETH market).
    // Only relative is the WEETH token, which is already ignoreDiscovery above.
    "eth:0x4270E1817576bbA4b640466bE79A408Ef128F828": {
      "ignoreInWatchMode": ["latestRoundData"]
    },
    // MorphoChainlinkOracleV2 for the weETH market.
    "eth:0xa3A7A3ceFee206f9d7Fe00eC3C83324ED4228411": {
      "ignoreInWatchMode": ["price"]
    },
    // DummyFeed used as QUOTE_FEED_1 in the new oracle (immutable internal stub).
    "eth:0xc3866d726C204C0836E0677A31973c649888973D": {
      "ignoreInWatchMode": ["latestRoundData", "getPrice"]
    },
    "eth:0xA6D6950c9F177F1De7f7757FB33539e3Ec60182a": {
      "ignoreMethods": ["price"]
    },
    "eth:0x0F948CBa8231Db7898ef36A4212581Ad7b1B4580": {
      "ignoreMethods": ["price"]
    },
    "eth:0x4F67e4d9BD67eFa28236013288737D39AeF48e79": {
      "ignoreMethods": ["latestRoundData"]
    },
    "eth:0xDddd770BADd886dF3864029e4B377B5F6a2B6b83": {
      "ignoreInWatchMode": ["price"]
    },
    "eth:0x48F7E36EB6B826B2dF4B2E630B62Cd25e89E40e2": {
      "ignoreInWatchMode": ["price"]
    },
    "eth:0x09dbf9502d43445b33883837a51D06Fc9B9CdEC4": {
      "ignoreInWatchMode": [
        "price"
      ]
    },
    "eth:0x0acdC416C592a592Edf2E64b178aA8d4d47e05A8": {
      "ignoreInWatchMode": [
        "price"
      ]
    },
    "eth:0x8c9464D99512Dcd6f80BE72aAc20dafD9Ea2C831": {
      "ignoreInWatchMode": [
        "price"
      ]
    },
    "eth:0x9F983115741D0F7F2EAE07831415057AD3de34d2": {
      "ignoreInWatchMode": [
        "backupPrice",
        "getDeviation",
        "price",
        "primaryPrice"
      ]
    },
    "eth:0xe087AD7FE989cF63F8383579D160a20Ee7e69F9F": {
      "ignoreInWatchMode": [
        "price"
      ]
    },
    "eth:0xf1561bC4b3D1bA49053986Fb9ee88D4fE22d0Cf4": {
      "ignoreInWatchMode": [
        "backupPrice",
        "getDeviation",
        "price",
        "primaryPrice"
      ]
    }
  }
}
